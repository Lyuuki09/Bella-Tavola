APP_NAME=Bella Tavola API
APP_VERSION=1.0.0
APP_DESCRIPTION=API do restaurante Bella Tavola
DEBUG=false
MAX_MESAS=20
MAX_PESSOAS_POR_MESA=10
MODEL_REPO_ID=seu-usuario/seu-modelo
MODEL_FILENAME=model.pkl
MODEL_VERSION=v1
# Usado no CI e em execucoes locais que baixam do Hugging Face Hub.
HF_TOKEN=hf_seu_token_aqui

# PostgreSQL (docker compose — servico db)
POSTGRES_USER=bella
POSTGRES_PASSWORD=secreta
POSTGRES_DB=bellatavolada

# String de conexao SQLAlchemy (sobrescrita pelo docker-compose em producao).
# DATABASE_URL=postgresql://bella:secreta@db:5432/bellatavolada
